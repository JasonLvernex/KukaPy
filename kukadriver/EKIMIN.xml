<ETHERNETKRL>
  <CONFIGURATION>
    <EXTERNAL>
      <IP>192.168.0.1</IP>
      <PORT>18736</PORT>
      <PROTOCOL>TCP</PROTOCOL>
      <SENDFLAG>1</SENDFLAG>
    </EXTERNAL>
  </CONFIGURATION>

  <RECEIVE>
    <XML>
      <ELEMENT Tag="Rob/Type" Type="INT" />
    </XML>
  </RECEIVE>

  <SEND>
    <XML>
      <ELEMENT Tag="Res/Code" Type="INT" />
      <ELEMENT Tag="Res/Val"  Type="INT" />
    </XML>
  </SEND>
</ETHERNETKRL>
